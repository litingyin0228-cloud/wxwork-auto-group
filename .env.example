APP_DEBUG = true

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
TYPE     = mysql
HOSTNAME = 127.0.0.1
DATABASE = wxwork_auto_group
USERNAME = root
PASSWORD = your_db_password
HOSTPORT = 3306
CHARSET  = utf8mb4
PREFIX   = 

[CACHE]
DRIVER = file

[LOG]
CHANNEL = file

# ─── 企业微信配置 ─────────────────────────────────────────────────
# 企业ID，在企业微信「我的企业」->「企业信息」中查看
WXWORK_CORP_ID          = your_corp_id

# 自建应用 Secret（「应用管理」->「自建」-> 对应应用）
WXWORK_CORP_SECRET      = your_corp_secret

# 客户联系 Secret（「客户联系」->「API」中查看）
WXWORK_CONTACT_SECRET   = your_contact_secret

# 回调 Token（「客户联系」->「API」->「指令回调URL」中填写）
WXWORK_CALLBACK_TOKEN   = your_callback_token

# 回调加密 EncodingAESKey
WXWORK_CALLBACK_AES_KEY = your_encoding_aes_key

# 自建应用 AgentID
WXWORK_AGENT_ID         = your_agent_id

# 自动建群时的群主 userid（企业内部成员）
WXWORK_GROUP_OWNER      = your_staff_userid

# ─── API 鉴权配置 ────────────────────────────────────────────────
# API 请求 Token，请求头 X-Api-Token 必须与此值一致才可访问业务接口
# 生成方式：openssl rand -hex 32（生产环境必须设置）
APP.API_TOKEN          =

# ─── 队列配置 ─────────────────────────────────────────────────
# 队列驱动：sync=同步（调试）、database=数据库、redis=Redis（生产推荐）
QUEUE_DRIVER = sync
REDIS.HOST  = 127.0.0.1
REDIS.PORT  = 6379
REDIS.PASSWORD =
REDIS.QUEUE_DB = 1
